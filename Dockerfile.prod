# Example for a Node.js app -- adapt the runtime commands/base image if
# your stack is Python, Go, etc. The STRUCTURE (build stage -> minimal
# runtime stage) is what matters, not this exact language.

# ---- Stage 1: build -------------------------------------------------
# Has compilers, dev dependencies, build tools. None of this ships.
FROM node:20-slim AS build

WORKDIR /app

# Install ALL dependencies (including dev) to build/compile
COPY package.json package-lock.json ./
RUN npm ci

# Now bring in source and build it (transpile, bundle, etc.)
COPY . .
RUN npm run build

# Prune dev dependencies, leaving only what's needed at runtime
RUN npm prune --omit=dev

# ---- Stage 2: runtime -------------------------------------------------
# Minimal base, no compilers, no dev tools, no agent CLI, no SSH.
FROM node:20-slim AS runtime

# Run as non-root
RUN useradd --uid 1000 -m appuser
USER appuser

WORKDIR /app

# Only copy the compiled output + pruned production dependencies --
# nothing from the build stage's tooling comes along.
COPY --from=build --chown=appuser:appuser /app/dist ./dist
COPY --from=build --chown=appuser:appuser /app/node_modules ./node_modules
COPY --from=build --chown=appuser:appuser /app/package.json ./package.json

# Secrets are NEVER baked in here via ENV/ARG -- they're injected at
# `docker run` / compose time from the VPS's own secret store.

EXPOSE 3000
CMD ["node", "dist/main.js"]
