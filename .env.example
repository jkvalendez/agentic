# Copy this file to .env and fill in your values.
# .env is read automatically by docker compose.

# Path on your HOST to the project you want the agent to work on.
# This is the ONLY host path that will be visible inside the container.
SOURCE_DIR=./my-project

# Provide whichever key(s) your chosen agent CLI / provider needs.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Your APP's own runtime secrets (if the agent needs to run the app),
# e.g. a database URL. These are injected as container env vars only --
# never write real values into a file inside SOURCE_DIR.
APP_DATABASE_URL=

# IMPORTANT: keep this .env file itself OUTSIDE SOURCE_DIR / your repo's
# bind-mounted folder. Docker compose reads it from wherever you run
# `docker compose` -- it does not need to live inside the mounted path.
